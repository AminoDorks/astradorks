{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "types": ["bun", "node"],

    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,

    "noEmit": false,

    "outDir": "./dist",
    "rootDir": "./src",

    // Imports без расширений
    "allowImportingTsExtensions": false,
    "rewriteRelativeImportExtensions": true,

    "strict": true,
    "skipLibCheck": true,
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
}
